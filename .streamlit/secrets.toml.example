# Modèle de secrets pour Streamlit Cloud.
# NE PAS committer le vrai fichier secrets.toml (il est ignoré par git).
#
# Sur Streamlit Cloud : Manage app -> Settings -> Secrets, et collez le contenu
# ci-dessous (avec votre vraie clé). En local : copiez ce fichier en
# `.streamlit/secrets.toml`.

# Clé The Odds API (gratuite : https://the-odds-api.com) pour les cotes en direct.
THE_ODDS_API_KEY = "votre_cle_the_odds_api"

# Paramètres optionnels (sinon valeurs par défaut du code) :
# BANKROLL = "100"
# MIN_VALUE_PERCENT = "5"
# KELLY_FRACTION = "0.25"
# ENSEMBLE_MARKET_WEIGHT = "0.6"
# ODDS_REGIONS = "eu,uk"
# SPORT_KEYS = "soccer_fifa_world_cup,soccer_epl,soccer_spain_la_liga"
